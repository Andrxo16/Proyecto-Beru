# Copia a .env.local en esta carpeta (BERU FRONTEND). No se sube a git; cada PC usa su propia URL si el API corre en otro host/puerto.

# URL base del FastAPI (BERUAPP) para el navegador y para el servidor Next.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Mismo origen para el route /api/proxy (llamadas server-side hacia el backend).
BERU_API_PROXY_TARGET=http://127.0.0.1:8000
