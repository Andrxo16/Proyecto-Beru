# Copia este archivo a .env en la carpeta BERUAPP y ajusta valores en cada computador.
# .env no se versiona; cada quien usa su propia conexion y claves.

# PostgreSQL (misma conexion que en pgAdmin). Codifica caracteres especiales en la URL (%40 para @, etc.).
DATABASE_URL=postgresql+psycopg2://postgrest:TU_CONTRASENA@127.0.0.1:5432/beru_db

# Firma de tokens JWT internos; debe ser distinta y secreta en produccion y por equipo si quieres invalidar sesiones al cambiar.
SECRET_KEY=genera_una_cadena_larga_y_unica_por_equipo
